# Environment variables for papersearch-research-assistant
# Copy to .env and fill in values

# LLM provider (at least one required)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Langfuse observability (optional — LLM calls work without it)
# Sign up at https://langfuse.com, create a project, copy keys here.
# When set, every LLM call is automatically traced (prompts, responses,
# latency, token usage, cost). When absent, tracing is silently skipped.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
